// Configuração para Banco de Dados Local (SQLite)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Session {
  id               String    @id @default(uuid())
  initial_bankroll Float
  current_bankroll Float
  highest_bankroll Float
  min_chip         Float
  status           String    // "ACTIVE", "CLOSED"
  created_at       DateTime  @default(now())
  closed_at        DateTime?
  spins            Spin[]
  signals          Signal[]
}

model Spin {
  id         String   @id @default(uuid())
  session_id String
  session    Session  @relation(fields: [session_id], references: [id])
  number     Int
  color      String
  parity     String
  dozen      String
  column     String
  half       String
  created_at DateTime @default(now())
}

model Strategy {
  id          String   @id @default(uuid())
  name        String   @unique
  description String
  is_active   Boolean  @default(true)
  signals     Signal[]
}

model Signal {
  id               String   @id @default(uuid())
  session_id       String
  session          Session  @relation(fields: [session_id], references: [id])
  strategy_id      String
  strategy         Strategy @relation(fields: [strategy_id], references: [id])
  type             String
  target           String
  suggested_amount Float    // Campo restaurado
  martingale_step  Int      @default(0) // Campo restaurado
  result           String   // "PENDING", "WIN", "LOSS", "MISSED", "SUGGESTED"
  created_at       DateTime @default(now())
}
