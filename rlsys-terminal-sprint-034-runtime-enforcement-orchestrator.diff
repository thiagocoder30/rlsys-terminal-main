@@ -0,0 +1,150 @@
+const test = require('node:test');
+const assert = require('node:assert');
+
+const {
+  RuntimeEnforcementOrchestrator
+} = require('../dist/domain/runtime/RuntimeEnforcementOrchestrator');
+
+function baseInput(overrides = {}) {
+  return {
+    dataIntegrityValid: true,
+    snapshotValid: true,
+    cooldownActive: false,
+    runtimeSanityStatus: 'SANITY_OK',
+    sessionCircuitStatus: 'SESSION_OPEN',
+    drawdownStatus: 'DRAWDOWN_OK',
+    healthStatus: 'HEALTHY',
+    strategyCandidateAvailable: true,
+    ...overrides
+  };
+}
+
+test('RuntimeEnforcementOrchestrator allows only when all guards are clear', () => {
+  const orchestrator = new RuntimeEnforcementOrchestrator();
+
+  const report = orchestrator.evaluate(baseInput());
+
+  assert.equal(report.verdict, 'ALLOW');
+  assert.equal(report.allowDecisionLayer, true);
+  assert.equal(report.primaryReason, 'ALL_GUARDS_CLEAR');
+});
+
+test('RuntimeEnforcementOrchestrator freezes on data integrity failure', () => {
+  const orchestrator = new RuntimeEnforcementOrchestrator();
+
+  const report = orchestrator.evaluate(
+    baseInput({ dataIntegrityValid: false })
+  );
+
+  assert.equal(report.verdict, 'FREEZE');
+  assert.equal(report.allowDecisionLayer, false);
+  assert.equal(report.primaryReason, 'DATA_INTEGRITY_FAILURE');
+});
+
+test('RuntimeEnforcementOrchestrator locks on paradigm break', () => {
+  const orchestrator = new RuntimeEnforcementOrchestrator();
+
+  const report = orchestrator.evaluate(
+    baseInput({ runtimeSanityStatus: 'PARADIGM_BREAK' })
+  );
+
+  assert.equal(report.verdict, 'LOCKED');
+  assert.equal(report.primaryReason, 'PARADIGM_BREAK');
+});
+
+test('RuntimeEnforcementOrchestrator locks on session circuit lock', () => {
+  const orchestrator = new RuntimeEnforcementOrchestrator();
+
+  const report = orchestrator.evaluate(
+    baseInput({ sessionCircuitStatus: 'SESSION_LOCKED' })
+  );
+
+  assert.equal(report.verdict, 'LOCKED');
+  assert.equal(report.primaryReason, 'SESSION_LOCKED');
+});
+
+test('RuntimeEnforcementOrchestrator locks on drawdown lock', () => {
+  const orchestrator = new RuntimeEnforcementOrchestrator();
+
+  const report = orchestrator.evaluate(
+    baseInput({ drawdownStatus: 'DRAWDOWN_LOCKED' })
+  );
+
+  assert.equal(report.verdict, 'LOCKED');
+  assert.equal(report.primaryReason, 'DRAWDOWN_LOCKED');
+});
+
+test('RuntimeEnforcementOrchestrator returns review for degraded non-fatal states', () => {
+  const orchestrator = new RuntimeEnforcementOrchestrator();
+
+  const report = orchestrator.evaluate(
+    baseInput({
+      runtimeSanityStatus: 'SANITY_REVIEW',
+      drawdownStatus: 'DRAWDOWN_REVIEW',
+      healthStatus: 'DEGRADED'
+    })
+  );
+
+  assert.equal(report.verdict, 'REVIEW');
+  assert.equal(report.allowDecisionLayer, false);
+  assert.equal(report.reasons.includes('SANITY_REVIEW_REQUIRED'), true);
+  assert.equal(report.reasons.includes('DRAWDOWN_REVIEW_REQUIRED'), true);
+});
+
+test('RuntimeEnforcementOrchestrator returns no go without strategy candidate', () => {
+  const orchestrator = new RuntimeEnforcementOrchestrator();
+
+  const report = orchestrator.evaluate(
+    baseInput({ strategyCandidateAvailable: false })
+  );
+
+  assert.equal(report.verdict, 'NO_GO');
+  assert.equal(report.primaryReason, 'NO_STRATEGY_CANDIDATE');
+});
+
+test('RuntimeEnforcementOrchestrator is deterministic for repeated inputs', () => {
+  const orchestrator = new RuntimeEnforcementOrchestrator();
+  const input = baseInput({ cooldownActive: true });
+
+  const first = orchestrator.evaluate(input);
+  const second = orchestrator.evaluate(input);
+
+  assert.deepEqual(first, second);
+});
+
+test('RuntimeEnforcementOrchestrator blocks malformed boolean fields', () => {
+  const orchestrator = new RuntimeEnforcementOrchestrator();
+
+  const report = orchestrator.evaluate(
+    baseInput({ dataIntegrityValid: 'yes' })
+  );
+
+  assert.equal(report.verdict, 'BLOCKED');
+  assert.equal(report.primaryReason, 'INVALID_DATA_INTEGRITY_FLAG');
+});
