+export type RuntimeEnforcementVerdict =
+  | 'ALLOW'
+  | 'NO_GO'
+  | 'REVIEW'
+  | 'FREEZE'
+  | 'LOCKED'
+  | 'BLOCKED';
+
+export type RuntimeSanityStatus =
+  | 'SANITY_OK'
+  | 'SANITY_REVIEW'
+  | 'PARADIGM_BREAK'
+  | 'BLOCKED';
+
+export type SessionCircuitStatus =
+  | 'SESSION_OPEN'
+  | 'SESSION_REVIEW'
+  | 'SESSION_LOCKED'
+  | 'SESSION_PROFIT_LOCKED'
+  | 'BLOCKED';
+
+export type RuntimeDrawdownStatus =
+  | 'DRAWDOWN_OK'
+  | 'DRAWDOWN_REVIEW'
+  | 'DRAWDOWN_LOCKED'
+  | 'BLOCKED';
+
+export type RuntimeHealthStatus =
+  | 'HEALTHY'
+  | 'DEGRADED'
+  | 'CRITICAL';
+
+export interface RuntimeEnforcementInput {
+  readonly dataIntegrityValid: boolean;
+  readonly snapshotValid: boolean;
+  readonly cooldownActive: boolean;
+  readonly runtimeSanityStatus: RuntimeSanityStatus;
+  readonly sessionCircuitStatus: SessionCircuitStatus;
+  readonly drawdownStatus: RuntimeDrawdownStatus;
+  readonly healthStatus: RuntimeHealthStatus;
+  readonly strategyCandidateAvailable: boolean;
+}
+
+export interface RuntimeEnforcementReport {
+  readonly verdict: RuntimeEnforcementVerdict;
+  readonly allowDecisionLayer: boolean;
+  readonly allowPaperLedgerRecord: boolean;
+  readonly severity: number;
+  readonly primaryReason: string;
+  readonly reasons: readonly string[];
+}
+
+const MAX_REASONS = 8;
+
+/**
+ * Centraliza a governança defensiva do runtime em uma avaliação O(1).
+ *
+ * O orquestrador não executa aposta e não mantém estado interno. Ele consolida
+ * guardas de sanidade, circuito de sessão, drawdown, cooldown e saúde runtime em
+ * um único veredito determinístico e auditável.
+ */
+export class RuntimeEnforcementOrchestrator {
+  public evaluate(input: RuntimeEnforcementInput): RuntimeEnforcementReport {
+    const validationError = this.validateInput(input);
+
+    if (validationError !== null) {
+      return this.report('BLOCKED', 100, validationError, [validationError]);
+    }
+
+    const reasons: string[] = [];
+
+    if (!input.dataIntegrityValid) {
+      reasons.push('DATA_INTEGRITY_FAILURE');
+
+      return this.report('FREEZE', 95, 'DATA_INTEGRITY_FAILURE', reasons);
+    }
+
+    if (!input.snapshotValid) {
+      reasons.push('SNAPSHOT_INVALID');
+
+      return this.report('FREEZE', 92, 'SNAPSHOT_INVALID', reasons);
+    }
+
+    if (input.runtimeSanityStatus === 'BLOCKED') {
+      reasons.push('RUNTIME_SANITY_BLOCKED');
+
+      return this.report('BLOCKED', 90, 'RUNTIME_SANITY_BLOCKED', reasons);
+    }
+
+    if (input.runtimeSanityStatus === 'PARADIGM_BREAK') {
+      reasons.push('PARADIGM_BREAK');
+
+      return this.report('LOCKED', 88, 'PARADIGM_BREAK', reasons);
+    }
+
+    if (input.sessionCircuitStatus === 'BLOCKED') {
+      reasons.push('SESSION_CIRCUIT_BLOCKED');
+
+      return this.report('BLOCKED', 86, 'SESSION_CIRCUIT_BLOCKED', reasons);
+    }
+
+    if (input.sessionCircuitStatus === 'SESSION_LOCKED') {
+      reasons.push('SESSION_LOCKED');
+
+      return this.report('LOCKED', 84, 'SESSION_LOCKED', reasons);
+    }
+
+    if (input.sessionCircuitStatus === 'SESSION_PROFIT_LOCKED') {
+      reasons.push('SESSION_PROFIT_LOCKED');
+
+      return this.report('LOCKED', 82, 'SESSION_PROFIT_LOCKED', reasons);
+    }
+
+    if (input.drawdownStatus === 'BLOCKED') {
+      reasons.push('DRAWDOWN_BLOCKED');
+
+      return this.report('BLOCKED', 80, 'DRAWDOWN_BLOCKED', reasons);
+    }
+
+    if (input.drawdownStatus === 'DRAWDOWN_LOCKED') {
+      reasons.push('DRAWDOWN_LOCKED');
+
+      return this.report('LOCKED', 78, 'DRAWDOWN_LOCKED', reasons);
+    }
+
+    if (input.cooldownActive) {
+      reasons.push('COOLDOWN_ACTIVE');
+
+      return this.report('NO_GO', 70, 'COOLDOWN_ACTIVE', reasons);
+    }
+
+    if (input.healthStatus === 'CRITICAL') {
+      reasons.push('RUNTIME_HEALTH_CRITICAL');
+
+      return this.report('FREEZE', 68, 'RUNTIME_HEALTH_CRITICAL', reasons);
+    }
+
+    if (input.runtimeSanityStatus === 'SANITY_REVIEW') {
+      reasons.push('SANITY_REVIEW_REQUIRED');
+    }
+
+    if (input.sessionCircuitStatus === 'SESSION_REVIEW') {
+      reasons.push('SESSION_REVIEW_REQUIRED');
+    }
+
+    if (input.drawdownStatus === 'DRAWDOWN_REVIEW') {
+      reasons.push('DRAWDOWN_REVIEW_REQUIRED');
+    }
+
+    if (input.healthStatus === 'DEGRADED') {
+      reasons.push('RUNTIME_HEALTH_DEGRADED');
+    }
+
+    if (reasons.length > 0) {
+      return this.report('REVIEW', 50, reasons[0], reasons);
+    }
+
+    if (!input.strategyCandidateAvailable) {
+      reasons.push('NO_STRATEGY_CANDIDATE');
+
+      return this.report('NO_GO', 20, 'NO_STRATEGY_CANDIDATE', reasons);
+    }
+
+    return this.report('ALLOW', 0, 'ALL_GUARDS_CLEAR', ['ALL_GUARDS_CLEAR']);
+  }
+
+  private validateInput(input: RuntimeEnforcementInput): string | null {
+    if (typeof input !== 'object' || input === null) {
+      return 'INVALID_ENFORCEMENT_INPUT';
+    }
+
+    if (typeof input.dataIntegrityValid !== 'boolean') {
+      return 'INVALID_DATA_INTEGRITY_FLAG';
+    }
+
+    if (typeof input.snapshotValid !== 'boolean') {
+      return 'INVALID_SNAPSHOT_FLAG';
+    }
+
+    if (typeof input.cooldownActive !== 'boolean') {
+      return 'INVALID_COOLDOWN_FLAG';
+    }
+
+    if (typeof input.strategyCandidateAvailable !== 'boolean') {
+      return 'INVALID_STRATEGY_CANDIDATE_FLAG';
+    }
+
+    return null;
+  }
+
+  private report(
+    verdict: RuntimeEnforcementVerdict,
+    severity: number,
+    primaryReason: string,
+    reasons: readonly string[]
+  ): RuntimeEnforcementReport {
+    return {
+      verdict,
+      allowDecisionLayer: verdict === 'ALLOW',
+      allowPaperLedgerRecord: verdict !== 'BLOCKED',
+      severity,
+      primaryReason,
+      reasons: reasons.slice(0, MAX_REASONS)
+    };
+  }
+}
