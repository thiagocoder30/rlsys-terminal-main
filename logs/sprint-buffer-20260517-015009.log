import sys
import json
import time
from adapters.mock_vision import MockCamera, MockOcrEngine

def run_satellite():
    """
    Loop principal de visão computacional.
    Complexidade Espacial O(1): Frames são descartados instantan
eamente.
    """
    camera = MockCamera()
    ocr = MockOcrEngine()

    # Para garantir que o Node.js tenha tempo de arrancar antes
do Python "gritar" dados
    time.sleep(2)

    try:
        while True:
            # 1. Tira a foto (ROI)
            frame = camera.get_frame()

            # 2. Extrai o texto
            read_result = ocr.extract_number(frame)

            # 3. Se encontrou um número, envia via Standard Outp
ut (Pipe)
            if read_result:
                payload = {
                    "sector": read_result.sector,
                    "dealerId": read_result.dealer_id
                }
