    {
      dealerId: 'dealer-gamma',
      rouletteNumber: 17,
      sequenceIndex: 0
    }
  ], 'dealer-gamma');

  assert.equal(result.ok, true);
  assert.equal(result.value.status, 'BLOCKED');
