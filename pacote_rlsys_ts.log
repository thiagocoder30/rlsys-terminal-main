function persistentVoisinsDataset(size = 900) {
  const voisins = [22, 18, 29, 7, 28, 12, 35, 3, 26, 0, 32, 15, 19, 4, 21, 2, 25];
  return Array.from({ length: size }, (_, index) => index % 5 === 0 ? (index % 37) : voisins[index % voisins.length]);
