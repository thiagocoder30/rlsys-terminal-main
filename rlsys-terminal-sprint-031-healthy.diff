+const test = require('node:test');
+const assert = require('node:assert');
+
+const {
+  SessionCircuitBreaker,
+  SessionStatus
+} = require('../dist/domain/runtime/SessionCircuitBreaker');
+
+const baseState = {
+  initialBankroll: 240,
+  currentBankroll: 240,
+  stopLossThreshold: 30,
+  stopWinThreshold: 20,
+  drawdownVelocityAlert: false,
+  sanityEngineState: 'HEALTHY',
+  dataIntegrityValid: true,
+  mandatoryCooldownActive: false
+};
+
+test('SessionCircuitBreaker returns SESSION_OPEN for healthy state', () => {
+  const status = SessionCircuitBreaker.evaluate(baseState);
+  assert.equal(status, SessionStatus.SESSION_OPEN);
+});
+
+test('SessionCircuitBreaker blocks when data integrity fails', () => {
+  const status = SessionCircuitBreaker.evaluate({
+    ...baseState,
+    dataIntegrityValid: false
+  });
+  assert.equal(status, SessionStatus.BLOCKED);
+});
+
+test('SessionCircuitBreaker locks when stop loss is reached', () => {
+  const status = SessionCircuitBreaker.evaluate({
+    ...baseState,
+    currentBankroll: 210
+  });
+  assert.equal(status, SessionStatus.SESSION_LOCKED);
+});
+
+test('SessionCircuitBreaker locks profit when stop win is reached', () => {
+  const status = SessionCircuitBreaker.evaluate({
+    ...baseState,
+    currentBankroll: 260
+  });
+  assert.equal(status, SessionStatus.SESSION_PROFIT_LOCKED);
+});
+
+test('SessionCircuitBreaker locks on paradigm break', () => {
+  const status = SessionCircuitBreaker.evaluate({
+    ...baseState,
+    sanityEngineState: 'PARADIGM_BREAK'
+  });
+  assert.equal(status, SessionStatus.SESSION_LOCKED);
+});
+
+test('SessionCircuitBreaker returns SESSION_REVIEW on drawdown velocity alert', () => {
+  const status = SessionCircuitBreaker.evaluate({
+    ...baseState,
+    drawdownVelocityAlert: true
+  });
+  assert.equal(status, SessionStatus.SESSION_REVIEW);
+});
+
+test('SessionCircuitBreaker returns SESSION_REVIEW on divergent sanity state', () => {
+  const status = SessionCircuitBreaker.evaluate({
+    ...baseState,
+    sanityEngineState: 'DIVERGENT'
+  });
+  assert.equal(status, SessionStatus.SESSION_REVIEW);
+});
+
+test('SessionCircuitBreaker blocks malformed numeric state', () => {
+  const status = SessionCircuitBreaker.evaluate({
+    ...baseState,
+    initialBankroll: 0
+  });
+  assert.equal(status, SessionStatus.BLOCKED);
+});
