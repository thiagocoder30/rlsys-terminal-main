#!/usr/bin/env bash
# ==============================================================================
# RL.SYS CORE — PAPER HUD UNIFICADO (Single Source of Truth)
# ==============================================================================
set -euo pipefail

DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )/.." && pwd )"
